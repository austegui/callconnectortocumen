PORT=3000
BASE_URL=https://your-widget-domain.example

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_twilio_api_secret
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Caller ID used when the browser call is bridged to a phone number.
# This should be a Twilio number on your account or a verified outgoing caller ID.
TWILIO_CALLER_ID=+15551234567

# This should be the Twilio phone number that is attached to Elastic SIP Trunking
# and imported into Retell, so Retell receives the call as a phone call and can transfer it.
DEFAULT_DESTINATION=+15557654321

# Optional per-route destinations. Same format as DEFAULT_DESTINATION.
SALES_DESTINATION=+15557654321
SUPPORT_DESTINATION=+15557654321

# Optional comma-separated allowlist for browser origins using the widget.
ALLOWED_ORIGINS=https://client-site.example
